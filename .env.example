APP_NAME="Technopath Commerce Intelligence"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=technopath_commerce
DB_USERNAME=tci
DB_PASSWORD=secret

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Cache / Session / Queue ───────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ─── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@technopathcommerce.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5-preview
OPENAI_MAX_TOKENS=4096

# ─── Shopify ───────────────────────────────────────────────────────────────────
# Stored per-integration in integrations.credentials_json (encrypted).
# These are fallback/default env vars only; per-client tokens live in the DB.
SHOPIFY_API_VERSION=2025-01

# ─── Adobe Commerce ────────────────────────────────────────────────────────────
ADOBE_COMMERCE_API_VERSION=V1

# ─── Google Analytics 4 ────────────────────────────────────────────────────────
# Service Account JSON path or JSON string (server-side auth).
GA4_SERVICE_ACCOUNT_JSON=
GA4_PROPERTY_ID=

# ─── Microsoft Clarity ─────────────────────────────────────────────────────────
# Bearer token stored per-integration in integrations.credentials_json (encrypted).
# API rate limit: 10 requests/project/day.
CLARITY_API_BASE_URL=https://www.clarity.ms/export-data/api/v1

# ─── Intelligence Engine ───────────────────────────────────────────────────────
# Overrides config/intelligence.php defaults if set.
INTELLIGENCE_NIGHTLY_RUN_TIME="02:00"

# ─── Google OAuth2 ─────────────────────────────────────────────────────────────
# Created in Google Cloud Console → APIs & Services → Credentials
# → + Create Credentials → OAuth 2.0 Client ID → Web application
# Authorized redirect URI: http://127.0.0.1:8080/google/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/google/oauth/callback

# ─── Customer Meeting Agent ────────────────────────────────────────────────────
# AI Provider (openrouter | openai | gemini) — see config/meeting_agent.php
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
# OPENAI_API_KEY is shared with the Intelligence Engine (above)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_MAX_TOKENS=4096

# Jira Cloud Integration
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=bot@yourcompany.com
JIRA_API_TOKEN=

# Company email domains (comma-separated) — used for attendee classification
COMPANY_EMAIL_DOMAINS=technopath.com
